# Copy this file to .env and fill in your local paths.
# .env is gitignored — never commit it.

# ── Android ──────────────────────────────────────────────
# macOS default: /Users/<you>/Library/Android/sdk
# Windows default: C:\Users\<you>\AppData\Local\Android\Sdk
ANDROID_SDK_HOME=

# NDK version subfolder, e.g. 27.0.12077973
ANDROID_NDK_HOME=

# Build settings
ANDROID_ABI=arm64-v8a
ANDROID_PLATFORM=android-21
ANDROID_BUILD_TYPE=RelWithDebInfo

# Local path to the native executable to profile (Android arm64 ELF)
# e.g. build_android/bin/sample_01_bad
ANDROID_TARGET_EXE=

# Where to push it on the device
ANDROID_TARGET_DEVICE_PATH=/data/local/tmp/target_exe

# ── simpleperf ────────────────────────────────────────────
# Events to record, comma-separated (default: cpu-cycles)
SIMPLEPERF_EVENTS=cpu-cycles

# Duration in seconds
SIMPLEPERF_DURATION=10

# Output perf.data path on device
SIMPLEPERF_OUTPUT=/data/local/tmp/perf.data

# Call graph method: fp (frame pointer, requires -fno-omit-frame-pointer) or dwarf
SIMPLEPERF_CALL_GRAPH=fp

# ── Host platform is detected automatically ───────────────
# No platform-specific config needed here.
# On macOS/Linux: uses adb from ANDROID_SDK_HOME/platform-tools
# On Windows:     same, ensure adb.exe is in PATH or SDK is set
